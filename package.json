{
  "name": "sac-language-support",
  "author": {
    "name": "Luuk Kablan",
    "email": "luuk@kablan.nl",
    "url": "https://sac.kablan.nl"
  },
  "displayName": "SaC (Single Assignment C) Language Support",
  "description": "VS Code extension providing language support and improved developer workflow for SaC (Single Assignment C), including syntax highlighting and compiler diagnostics.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sac",
        "aliases": [
          "SaC",
          "sac"
        ],
        "extensions": [
          ".sac"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sac",
        "scopeName": "source.sac",
        "path": "./syntaxes/sac.tmLanguage.json"
      }
    ],
    "fileIcons": [
      {
        "extensions": [
          "sac"
        ],
        "icon": "./icons/logo.png"
      }
    ],
    "iconThemes": [
      {
        "id": "sac-icon-theme",
        "label": "SaC Icon Theme",
        "path": "./icons/sac-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "keyword.control.module.sac",
            "settings": {
              "foreground": "#C586C0",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.control.import.sac",
            "settings": {
              "foreground": "#C2532C",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "entity.name.module.sac",
            "settings": {
              "foreground": "#D98A6A"
            }
          },
          {
            "scope": "keyword.operator.withloop.sac",
            "settings": {
              "foreground": "#C2532C",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "support.function.builtin.sac",
            "settings": {
              "foreground": "#C2532C",
              "fontStyle": "bold"
            }
          },
          {
            "scope": [
              "entity.name.function.sac",
              "support.function.call.sac"
            ],
            "settings": {
              "foreground": "#E8BF6A"
            }
          },
          {
            "scope": [
              "storage.type.pattern.sac",
              "storage.type.rank.sac"
            ],
            "settings": {
              "foreground": "#4EC9B0"
            }
          },
          {
            "scope": [
              "variable.parameter.shape.sac",
              "variable.parameter.rank.sac"
            ],
            "settings": {
              "foreground": "#FFFFFF"
            }
          },
          {
            "scope": [
              "keyword.operator.shape.separator.sac",
              "keyword.operator.guard.sac",
              "punctuation.section.brackets.begin.sac",
              "punctuation.section.brackets.end.sac",
              "punctuation.separator.comma.sac"
            ],
            "settings": {
              "foreground": "#8FA7B3"
            }
          },
          {
            "scope": "keyword.control.directive.pragma.sac",
            "settings": {
              "foreground": "#00AAAA",
              "fontStyle": "italic"
            }
          }
        ]
      }
    }
  }
}