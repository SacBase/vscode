{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "paths": {
      "$settings": ["./src/extension/settings.ts"],
      "$sac2c/*": ["./src/sac2c/*"],
      "$util/*": ["./src/util/*"],
      "$extension/*": ["./src/extension/*"],
      "$constants/*": ["./src/constants/*"],
      "$lsp-server/*": ["./src/lsp-server/*"],
      "$copilot/*": ["./src/copilot/*"]
    },
    "lib": ["ES2020"],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node16",
    "skipLibCheck": true,
    "types": ["node", "vscode"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}
