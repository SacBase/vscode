{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "paths": {
      "$core/*": [
        "./src/core/*"
      ],
      "$server/*": [
        "./src/server/*"
      ],
      "$extension/*": [
        "./src/extension/*"
      ]
    },
    "lib": [
      "ES2020"
    ],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node16",
    "skipLibCheck": true,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}